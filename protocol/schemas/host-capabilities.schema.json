{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0thcanvas.com/schemas/host-capabilities.schema.json",
  "title": "Observed host capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "harness",
    "source",
    "observed_at",
    "model",
    "reasoning_effort",
    "available_models",
    "available_reasoning_efforts",
    "model_override",
    "effort_override",
    "max_parallelism",
    "max_depth",
    "workspace_isolation",
    "resume",
    "hooks",
    "external_write_controls"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "harness": { "type": "string", "minLength": 1 },
    "source": { "enum": ["documented-only", "session-metadata", "runtime-probe"] },
    "observed_at": { "type": ["string", "null"], "format": "date-time" },
    "model": { "type": ["string", "null"] },
    "reasoning_effort": {
      "type": ["string", "null"],
      "enum": [null, "low", "medium", "high", "xhigh", "max"]
    },
    "available_models": {
      "type": ["array", "null"],
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "available_reasoning_efforts": {
      "type": ["array", "null"],
      "items": { "enum": ["low", "medium", "high", "xhigh", "max"] },
      "uniqueItems": true
    },
    "model_override": { "type": "boolean" },
    "effort_override": { "type": "boolean" },
    "max_parallelism": { "type": ["integer", "null"], "minimum": 1 },
    "max_depth": { "type": ["integer", "null"], "minimum": 0 },
    "workspace_isolation": { "type": ["boolean", "null"] },
    "resume": { "type": ["boolean", "null"] },
    "hooks": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "external_write_controls": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "source": { "not": { "const": "documented-only" } } } },
      "then": { "properties": { "observed_at": { "type": "string" } } }
    }
  ]
}
