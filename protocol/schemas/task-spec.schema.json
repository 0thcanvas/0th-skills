{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0thcanvas.com/schemas/task-spec.schema.json",
  "title": "Task specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "outcome", "acceptance", "non_goals", "proof_tier", "risk", "authority"],
  "properties": {
    "schema_version": { "const": 1 },
    "outcome": { "type": "string", "minLength": 1 },
    "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "non_goals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "proof_tier": { "enum": ["T0", "T1", "T2", "T3", "T4"] },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_edits", "non_destructive_tests", "push_branch", "open_pr", "merge"],
      "properties": {
        "local_edits": { "type": "boolean" },
        "non_destructive_tests": { "type": "boolean" },
        "push_branch": { "type": "boolean" },
        "open_pr": { "type": "boolean" },
        "merge": { "type": "boolean" }
      }
    }
  }
}
